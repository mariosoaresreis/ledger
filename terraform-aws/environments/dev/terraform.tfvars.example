# Copy to terraform.tfvars and fill in your values.
# Never commit terraform.tfvars to version control.
region             = "us-east-1"
environment        = "dev"
db_password        = "CHANGE_ME"
db_instance_class  = "db.t3.micro"
node_instance_type = "t3.medium"
node_count         = 2
min_nodes          = 1
max_nodes          = 3
app_image_tag      = "latest"
app_replicas       = 1
kafka_replicas     = 1

